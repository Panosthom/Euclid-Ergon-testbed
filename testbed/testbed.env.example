# Copy to testbed/testbed.env and edit. Sourced by activate.sh and scripts/*.sh.

# Absolute path to the SHARED platform install (NOT your home). This is the dir
# that contains registry/, experiments/, extensions/, controller/. Case-sensitive!
# Find the exact path/case as the platform user with:  ls -d ~/*/registry/
# Example today: /home/pi-server/federated-edge-testbed   (lowercase)
# After relocation to a shared spot: /opt/fl-edge-platform
# It must match controller/config.json "remote_repo" and be the same on all Pis.
PLATFORM_DIR="/home/pi-server/federated-edge-testbed"

# How to activate the shared Python venv (with torch/flwr/numpy). activate.sh runs
# this. Leave empty if the platform is importable without a venv.
VENV_ACTIVATE="source /home/pi-server/.venv/fed/bin/activate"

# Platform controller config with the physical node inventory (server + 4 clients).
# This is the LIVE single source of truth, admin-maintained once on the server Pi;
# the scripts read node IPs/users/keys from it. For the schema / to bootstrap a
# fresh testbed, see testbed/controller.config.example.json (reference only).
CONTROLLER_CONFIG="$PLATFORM_DIR/controller/config.json"

# Your student workspace = this template clone on the server Pi.
STUDENT_WORKSPACE="$PWD"

# Dataset name; must match your ExperimentSpec and the shards you prepared.
DATASET="mnist"

# Exclusive-access lock for the 4 physical client Pis (shared across all students
# on the server Pi). Anyone running a Pi experiment must hold this.
TESTBED_LOCK="/tmp/fl-edge-testbed.lock"

# Shared deploy key used to reach the Pis. This is the fallback when a node in
# controller/config.json has no "key"; normally config.json itself points every
# node at this same shared key. It must be readable by your group (e.g. fledge)
# and authorized on every node -- the admin sets this up once (see ADMIN_SETUP).
SSH_KEY="/etc/fl-testbed/deploy_key"
