{
  "experiment": {
    "name": "example_mnist_fedavg_legacy",
    "framework": "flower",
    "seed": 2025,
    "output_root": "logs"
  },
  "dataset": {
    "name": "mnist",
    "data_dir": "data/mnist"
  },
  "federation": {
    "server_address": "127.0.0.1:8081",
    "num_rounds": 10,
    "num_clients": 4,
    "min_clients": 4
  },
  "model": {
    "name": "example_cnn",
    "source": "plugins.models.example_model:build_model"
  },
  "client": {
    "local_epochs": 1,
    "batch_size": 32,
    "allow_fallback": false,
    "enable_codecarbon": false,
    "enable_checkpoints": true
  },
  "network": {
    "latency_ms": 0,
    "bandwidth_kbps": 0,
    "dropout_prob": 0.0
  }
}
